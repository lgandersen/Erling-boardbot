%% -*- erlang -*-
%% Erling reads all of its own configuration from environment variables at
%% startup (see erling_config), with the defaults in erling.app.src. This file
%% therefore only configures the runtime's own logging.
[
 {kernel, [
   {logger_level, info},
   {logger, [
     {handler, default, logger_std_h,
      #{formatter => {logger_formatter,
                      #{legacy_header => false,
                        single_line => true,
                        template => [time, " ", level, " ", msg, "\n"]}}}}
   ]}
 ]}
].
