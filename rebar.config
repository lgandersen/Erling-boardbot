%% -*- erlang -*-
{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_unused_import
]}.

%% epgsql 4.8.0 is the newest hex release (2025-06-06) and the one that builds
%% clean on OTP 27+/29; 4.7.1 dates from 2023 and predates those releases.
%% Pinned exactly -- the old rebar2 config tracked epgsql git master unpinned.
{deps, [
    {epgsql, "4.8.0"}
]}.

{shell, [
    {apps, [erling]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {include_src, false},
            {debug_info, strip}
        ]}
    ]},
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]}
    ]}
]}.

{relx, [
    {release, {erling, "2.0.0"}, [
        sasl,
        erling
    ]},
    %% All service configuration comes from the environment at startup (see
    %% erling_config); sys.config only configures the runtime's logging.
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"},
    {extended_start_script, true}
]}.

{dialyzer, [
    {warnings, [unknown]},
    {plt_apps, all_deps},
    {plt_extra_apps, [ssl, public_key, crypto, epgsql]}
]}.

{eunit_opts, [verbose]}.

{xref_checks, [
    undefined_function_calls,
    locals_not_used,
    deprecated_function_calls
]}.
